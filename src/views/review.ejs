<%- include("partials/header") %>
<h1>Applications</h1>

<% applications.forEach(application => { %>
    <div>
        <h2><%= application.first_name %> <%= application.last_name %></h2>
        <p>Loan Type: <%= capitalize(application.loan_type) %></p>
        <p>Amount: <%= application.amount %></p>
        <p>Income: <%= application.income_amount %></p>
        <p>Employer: <%= capitalize(application.employer_name) %></p>
        <hr>
    </div>
<% }) %>
<%- include("partials/footer") %>