<%- include("partials/header") %>
<main>
    <h1>My Loan Applications</h1>

    <% if (loans.length === 0) { %>
        <p>You have not submitted any loan applications yet.</p>
    <% } %>

    <% loans.forEach(loan => { %>
        <section>
            <form action="post" method="POST">
                <div>
                    <h2><%= capitalize(loan.loan_type) %> Loan</h2>
                    <p>Applicant: <%= loan.first_name %> <%= loan.last_name %></p>
                    <p>Amount: $<%= loan.amount %></p>
                    <p>Term: <%= loan.term %> months</p>
                    <p>Status: 
                        <span class="<%= loan.status.toLowerCase() %>">
                            <%= capitalize(loan.status) %>
                        </span>
                    </p>
                </div>
            </form>
        </section>
    <% }) %>
</main>
<%- include("partials/footer") %>